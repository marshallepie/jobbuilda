# Coordinator API Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://jobbuilda:jobbuilda@localhost:5432/identity_mcp

# NATS Event Bus
NATS_URL=nats://localhost:4222

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# For development, you can use 're_123' as a test key (emails won't actually send)
RESEND_API_KEY=re_123
EMAIL_FROM_ADDRESS=JobBuilda <noreply@jobbuilda.com>

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_QUOTE_WEBHOOK_SECRET=whsec_your_quote_deposit_webhook_secret

# Portal URL (for deposit payment links and webhook redirects)
PORTAL_URL=https://your-portal-domain.com

# Admin URL (for Stripe Connect onboarding redirect URLs)
ADMIN_URL=https://your-admin-domain.com

# Stripe Connect platform client ID (from Stripe Dashboard → Connect settings)
# Only required if using the OAuth flow; Express account creation (used here) does not need it.
# STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# Authentication (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
